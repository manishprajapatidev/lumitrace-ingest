# --- Server ---
NODE_ENV=development
PORT=8080
HOST=0.0.0.0
LOG_LEVEL=info
TRUST_PROXY=true

# --- Postgres / TimescaleDB ---
DATABASE_URL=postgresql://neondb_owner:npg_YTW7Qkb8qFcf@ep-icy-bush-a1e2xjpb-pooler.ap-southeast-1.aws.neon.tech/lumitrace?sslmode=require&channel_binding=require
PG_POOL_MAX=20
PG_IDLE_TIMEOUT_MS=30000
PG_CONNECTION_TIMEOUT_MS=5000

# --- Auth (HS256 JWT for admin/user routes) ---
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=change-me-in-production-please-use-a-long-random-value
JWT_ISSUER=lumitrace
JWT_AUDIENCE=lumitrace-api

# --- CORS for admin / SSE endpoints (comma-separated). Ingest is token-only. ---
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Ingest limits ---
INGEST_MAX_BODY_BYTES=1048576    # 1 MB
INGEST_MAX_LINES=1000
INGEST_MAX_LINE_BYTES=32768      # 32 KB
INGEST_RATE_PER_TOKEN_PER_MIN=3000

# --- Token issuance ---
TOKEN_BYTES=32
TOKEN_PREFIX=lt
